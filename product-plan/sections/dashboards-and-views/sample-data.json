{
  "_meta": {
    "models": {
      "recentChart": "A recently added chart shown on the Main Dashboard, with basic metadata for card rendering.",
      "buriedTreasure": "An unstarted chart that has been in the library the longest, surfaced to encourage rediscovery.",
      "spotlightProject": "A randomly selected project shown as a large featured card on the Main Dashboard.",
      "whatsNextProject": "A kitted or want-to-start project shown on Pattern Dive's What's Next tab, sorted by priority.",
      "fabricRequirementRow": "A project with calculated fabric dimensions at multiple counts, shown on Pattern Dive's Fabric Requirements tab.",
      "storageGroup": "A storage location with its assigned projects and fabric, shown on Pattern Dive's Storage View tab.",
      "projectGoals": "A project's planning data: priority ranking, milestones, timing preferences, rotation schedule, and notes.",
      "projectMilestone": "A single milestone goal within a project's plan (e.g., 'Reach 25%') with optional target date and completion status.",
      "shoppingThreadNeed": "An unfulfilled thread need aggregated across projects for the Shopping Cart.",
      "shoppingBeadNeed": "An unfulfilled bead need aggregated across projects for the Shopping Cart.",
      "shoppingSpecialtyNeed": "An unfulfilled specialty item need aggregated across projects for the Shopping Cart.",
      "shoppingFabricNeed": "A fabric that needs to be purchased, either from need-to-buy flag or from an unassigned project requirement.",
      "shoppingCartSummary": "Aggregate counts and per-project breakdown of all shopping needs.",
      "collectionStats": "Aggregate statistics about the user's entire cross stitch collection, shown in the dashboard sidebar.",
      "goalsSummary": "Teaser summary of upcoming milestones and planned project starts, shown on the dashboard with a link to the full Goals view."
    },
    "relationships": [
      "RecentChart and BuriedTreasure are read-only projections of Chart + Project data",
      "SpotlightProject is a randomly selected Project + Chart projection",
      "WhatsNextProject is filtered from Projects where status is Kitted or wantToStartNext is true",
      "FabricRequirementRow is computed from Project.stitchesWide/stitchesHigh at multiple fabric counts",
      "StorageGroup groups Projects and Fabrics by StorageLocation",
      "ProjectGoals belongs to Project, contains many ProjectMilestone",
      "ShoppingThreadNeed aggregates ProjectThread records where isFulfilled is false, grouped by Thread",
      "ShoppingFabricNeed comes from Fabric.needToBuy or Projects without assigned fabric",
      "ShoppingCartSummary is computed from all shopping need arrays",
      "CollectionStats is computed from all Projects",
      "GoalsSummary is computed from ProjectGoals with upcoming milestones and planned starts"
    ]
  },
