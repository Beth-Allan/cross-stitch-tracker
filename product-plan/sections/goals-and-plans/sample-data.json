{
  "_meta": {
    "models": {
      "Goal": "A measurable target the user wants to hit — either project-specific (milestone, frequency, deadline, session count) or global (volume, consistency, project completion, project start, manual). Tracks progress automatically from session logging or manually via check-off.",
      "Plan": "A scheduling intention linking a project to a date or recurring schedule — start dates, deadlines, recurring stitching days, or seasonal focus periods.",
      "Rotation": "A system for dividing stitching time across multiple WIPs. Supports multiple styles (round robin, focus+rotate, daily assignment, milestone, random, seasonal) with per-project turn triggers.",
      "RotationProject": "A project's membership in a rotation, including its position in the queue, turn trigger configuration, and current turn progress.",
      "Achievement": "A pre-defined auto-tracked milestone that unlocks when the user's stitching data reaches a threshold. Browsable in a trophy case grid.",
      "ProjectSummary": "A lightweight project reference used in goals, plans, and rotations — contains just enough info to display project cards and thumbnails."
    },
    "relationships": [
      "Goal optionally belongs to a Project (null for global goals)",
      "Plan belongs to a Project",
      "Rotation has many RotationProjects",
      "RotationProject references a Project",
      "Achievement is standalone (auto-tracked from aggregate data)"
    ]
  },

