# Database (Neon)
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_USER_EMAIL="your-email@example.com"
# IMPORTANT: Escape $ signs with \$ in bcrypt hashes (Next.js interprets $ as variable substitution)
AUTH_USER_PASSWORD_HASH="\$2b\$10\$your-bcrypt-hash-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-api-token-access-key"
R2_SECRET_ACCESS_KEY="your-r2-api-token-secret"
R2_BUCKET_NAME="cross-stitch-tracker"
